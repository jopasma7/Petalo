{
    "name": "floristeria-manager",
    "version": "1.0.0",
    "description": "Sistema de Gestión para Floristería - Manejo de inventario, clientes, eventos y pedidos especiales",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder",
        "pack": "electron-builder --dir",
        "dist": "electron-builder --publish=never",
        "postinstall": "electron-rebuild -f -w better-sqlite3",
        "rebuild": "electron-rebuild -f -w better-sqlite3"
    },
    "keywords": [
        "floristeria",
        "gestión",
        "inventario",
        "eventos",
        "jardineras",
        "electron",
        "desktop"
    ],
    "author": "Tu Nombre",
    "license": "MIT",
    "devDependencies": {
        "@electron/rebuild": "^3.7.2",
        "electron": "^30.0.0",
        "electron-builder": "^24.6.3"
    },
    "dependencies": {
        "better-sqlite3": "^12.10.0",
        "jspdf": "^4.2.1",
        "node-machine-id": "^1.1.12",
        "xlsx": "^0.18.5"
    },
    "build": {
        "appId": "com.tuempresa.floristeria",
        "productName": "Gestión de Floristería",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!**/*.ts",
            "!*.code-workspace",
            "!LICENSE.md",
            "!package.json.md",
            "!.gitignore",
            "!README.md",
            "!yarn.lock",
            "!**/*.map",
            "!dist",
            "!docs",
            "!.editorconfig",
            "!**/.*"
        ]
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/jopasma7/Trabajos.git"
    }
}
